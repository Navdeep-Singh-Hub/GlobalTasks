# --- Server
PORT=5000
NODE_ENV=development

# --- Database
# Local:
# MONGODB_URI=mongodb://127.0.0.1:27017/tms
# Atlas (use your SRV string; whitelist Render/Vercel IPs in Atlas → Network Access as needed)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>

# --- Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# --- CORS (used by Vercel + local dev)
# You can set either CLIENT_ORIGIN (single) or CLIENT_ORIGINS (comma-separated).
# Trailing slash is optional; the server normalizes it.
CLIENT_ORIGIN=http://localhost:3000
# Example:
# CLIENT_ORIGINS=https://your-app.vercel.app,https://some-preview.vercel.app,http://localhost:3000

# --- Jobs (optional)
# RECYCLE_BIN_RETENTION_DAYS=10
# RECYCLE_BIN_PURGE_INTERVAL_MS=86400000
