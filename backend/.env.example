PORT=5000
# Local dev (no Atlas IP whitelist needed):
MONGODB_URI=mongodb://127.0.0.1:27017/globaltasks
# Atlas: use your SRV string and whitelist your IP in Atlas → Network Access.
# If you see ReplicaSetNoPrimary / "IP isn't whitelisted", fix Network Access first.
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:3000
# Permanently delete soft-deleted tasks after this many days (default 10)
RECYCLE_BIN_RETENTION_DAYS=10
# How often to run purge job in ms (default 86400000 = 24h)
# RECYCLE_BIN_PURGE_INTERVAL_MS=86400000

