# --- Server
PORT=5000
NODE_ENV=development

# --- Database
# Local:
# MONGODB_URI=mongodb://127.0.0.1:27017/tms
# Atlas (use your SRV string; whitelist Render/Vercel IPs in Atlas → Network Access as needed)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>

# --- Auth
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# --- CORS (used by Vercel + local dev)
# You can set either CLIENT_ORIGIN (single) or CLIENT_ORIGINS (comma-separated).
# Trailing slash is optional; the server normalizes it.
CLIENT_ORIGIN=http://localhost:3000
# Example:
# CLIENT_ORIGINS=https://your-app.vercel.app,https://some-preview.vercel.app,http://localhost:3000

# --- Jobs (optional)
# RECYCLE_BIN_RETENTION_DAYS=10
# RECYCLE_BIN_PURGE_INTERVAL_MS=86400000

# --- WhatsApp digest integration (optional; if unset, logs in stub mode)
# Meta WhatsApp Cloud API credentials:
# WHATSAPP_PHONE_NUMBER_ID=343403298856238
# WHATSAPP_ACCESS_TOKEN=your-meta-permanent-token
# Fallback recipient when target phone missing (E.164 without + also works):
# WHATSAPP_ADMIN_PHONE=918146077145
# Scheduler controls (IST by default):
# WHATSAPP_DIGEST_SCHEDULER_ENABLED=true
# WHATSAPP_DIGEST_TIMEZONE=Asia/Kolkata
# WHATSAPP_MORNING_AT=09:45
# WHATSAPP_EVENING_AT=17:59
# Optional approved template names for production digests:
# WHATSAPP_TEMPLATE_MORNING=globaltasks_morning_digest_v1
# WHATSAPP_TEMPLATE_EVENING=globaltasks_evening_summary_v1
# WHATSAPP_TEMPLATE_LANGUAGE=en
